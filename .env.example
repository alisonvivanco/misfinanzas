# ============================================
# MisFinanzas — Variables de entorno
# Copia este archivo como .env.local y completa.
# ============================================

# --- Base ---
NEXT_PUBLIC_APP_NAME="MisFinanzas"
NEXT_PUBLIC_APP_URL="https://misfinanzas.alisonvivanco.cl"
NEXT_PUBLIC_SUPPORT_EMAIL="hola@misfinanzas.alisonvivanco.cl"

# --- MongoDB Atlas ---
# Crea cluster gratis en https://cloud.mongodb.com
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/misfinanzas?retryWrites=true&w=majority"
MONGODB_DB="misfinanzas"

# --- Auth.js (NextAuth v5) ---
# Generar con: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="https://misfinanzas.alisonvivanco.cl"
AUTH_TRUST_HOST="true"

# --- Google OAuth ---
# https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized redirect URI: https://misfinanzas.alisonvivanco.cl/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- Email transaccional (Resend) ---
# https://resend.com — plan free 3k emails/mes
RESEND_API_KEY=""
EMAIL_FROM="MisFinanzas <no-responder@misfinanzas.alisonvivanco.cl>"

# --- SII Chile ---
# (placeholder for future direct integration — no OAuth client needed today)

# --- UF/UTM (mindicador.cl público sin key) ---
MINDICADOR_API_URL="https://mindicador.cl/api"

# --- MercadoPago (suscripciones) ---
# Plan de suscripción Preapproval. Genera el plan en
# https://www.mercadopago.cl/subscriptions
NEXT_PUBLIC_SUBSCRIBE_URL="https://www.mercadopago.cl/subscriptions/checkout?preapproval_plan_id=50b7a4d225194f30a3a03b1e4c09bea9"
NEXT_PUBLIC_MANAGE_SUBSCRIPTION_URL="https://www.mercadopago.cl/subscriptions"

# --- Límites y configuración ---
FREE_TRIAL_DAYS="1"
MAX_FREE_BOLETAS="10"

# --- Site-wide access gate ---
# Single shared password that protects ALL pages (private soft-launch).
# If unset, the gate falls back to the default in src/lib/site-gate.ts.
SITE_PASSWORD="Deuditas!"
